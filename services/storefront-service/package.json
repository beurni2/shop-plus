{
  "name": "@shop-plus/storefront-service",
  "version": "0.0.1",
  "private": true,
  "description": "Workers service stub (WO-SP0.1): folder, types, health endpoint — no features.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p worker/tsconfig.json",
    "test": "vitest run",
    "bundle:worker": "esbuild worker/storefront-do.ts --bundle --format=esm --outfile=dist/worker/storefront-worker.mjs --platform=neutral --conditions=import",
    "bundle:worker:listing": "esbuild worker/listing-do.ts --bundle --format=esm --outfile=dist/worker/listing-worker.mjs --platform=neutral --conditions=import",
    "bundle:worker:combined": "esbuild worker/index.ts --bundle --format=esm --outfile=dist/worker/worker.mjs --platform=neutral --conditions=import",
    "pretest": "pnpm bundle:worker && pnpm bundle:worker:listing && pnpm bundle:worker:combined"
  },
  "dependencies": {
    "@shop-plus/observability": "workspace:*",
    "@platform/contracts": "git+https://github.com/beurni2/platform-contracts.git#d7b27bb895667f751d522680282549f16335e631&path:packages/contracts"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "@cloudflare/workers-types": "^4.20250705.0",
    "esbuild": "^0.25.5",
    "miniflare": "^4.20250705.0"
  }
}
