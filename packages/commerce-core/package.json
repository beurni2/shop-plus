{
  "name": "@shop-plus/commerce-core",
  "version": "0.0.1",
  "private": true,
  "description": "THE authoritative commerce-core (ADR-002, founder ruling E1-D1): immutable Quote issuance, atomic reservation DO, thin E1 order state machine, EscrowTxn/SettlementObligation ledger records \u2014 all on the pinned canonical shapes.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p worker/tsconfig.json",
    "test": "vitest run",
    "bundle:worker": "esbuild worker/reservation-do.ts --bundle --format=esm --outfile=dist-worker/reservation-worker.mjs --platform=neutral --conditions=import",
    "pretest": "pnpm bundle:worker"
  },
  "dependencies": {
    "@platform/contracts": "git+https://github.com/beurni2/platform-contracts.git#a832df0a8ed9e9fc83083826bc11c2a2e57e615a&path:packages/contracts",
    "@platform/kernel-types": "git+https://github.com/beurni2/platform-contracts.git#a832df0a8ed9e9fc83083826bc11c2a2e57e615a&path:packages/kernel-types",
    "@shop-plus/flags-client": "workspace:*"
  },
  "devDependencies": {
    "@platform/certification": "git+https://github.com/beurni2/platform-contracts.git#a832df0a8ed9e9fc83083826bc11c2a2e57e615a&path:packages/certification",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "@cloudflare/workers-types": "^4.20250705.0",
    "esbuild": "^0.25.5",
    "miniflare": "^4.20250705.0"
  }
}
